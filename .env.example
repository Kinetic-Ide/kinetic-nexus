# Required
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus
REDIS_URL=redis://localhost:6379

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=your_64_hex_chars_here

# Dashboard admin password (set anything you want)
ADMIN_PASSWORD=change_me_strong_password

# Optional
PORT=3000
LOG_LEVEL=info

# Abuse guard — DoS/abuse backstop, NOT a throughput cap.
# Real throughput is controlled per-key by provider RPM/TPM inside the pool.
# Size this above your busiest single credential's expected rate. Per credential
# (each team key = its own bucket). Default 12000/min (200 req/s). See README.
ABUSE_RATE_LIMIT_MAX=12000
ABUSE_RATE_LIMIT_WINDOW=1 minute

# Admission & upstream timeouts (all optional).
# Output tokens reserved against a key's TPM budget when a request omits
# max_tokens (reconciled to real usage after the response).
NEXUS_DEFAULT_MAX_TOKENS=2048
# Time-to-first-byte: abort if the provider doesn't return response headers in time (ms).
UPSTREAM_TTFT_MS=20000
# Non-streaming: max time to read the full response body (ms).
UPSTREAM_BODY_MS=60000
# Streaming: max gap allowed between chunks before a hung stream is aborted (ms).
UPSTREAM_STREAM_IDLE_MS=30000

# SSRF protection (network security) — sets the baseline; the dashboard Settings
# tab can add more allowlisted hosts on top of these at runtime.
# Blocking is ON by default: provider URLs pointing at private/loopback/internal
# addresses are refused. Set to true ONLY on a fully trusted network.
SSRF_ALLOW_PRIVATE=false
# Comma-separated hosts to permit even while blocking is on — for local providers
# (e.g. Ollama). Use host or host:port, no scheme. Example:
#   SSRF_ALLOWLIST=localhost:11434,127.0.0.1:11434
SSRF_ALLOWLIST=
