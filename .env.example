# Required
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus
REDIS_URL=redis://localhost:6379

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=your_64_hex_chars_here

# The gateway's deployment secret. NOT a day-to-day login (Phase 7.13a).
#
# It does exactly two things: it CLAIMS the first owner account when you first open the
# dashboard, and it authorises a full reset of the gateway. Once an owner account exists,
# this password is refused as a sign-in — everyone signs in with their own email and
# password, so the audit trail can name who did what and people can be removed one by one.
#
# Keep it: it is how you prove you are the person who installed this gateway.
ADMIN_PASSWORD=change_me_strong_password

# Optional
PORT=3000
LOG_LEVEL=info

# Abuse guard — DoS/abuse backstop, NOT a throughput cap.
# Real throughput is controlled per-key by provider RPM/TPM inside the pool.
# Size this above your busiest single credential's expected rate. Per credential
# (each team key = its own bucket). Default 12000/min (200 req/s). See README.
ABUSE_RATE_LIMIT_MAX=12000
ABUSE_RATE_LIMIT_WINDOW=1 minute

# Admission & upstream timeouts (all optional).
# Output tokens reserved against a key's TPM budget when a request omits
# max_tokens (reconciled to real usage after the response).
NEXUS_DEFAULT_MAX_TOKENS=2048
# Time-to-first-byte: abort if the provider doesn't return response headers in time (ms).
UPSTREAM_TTFT_MS=20000
# Non-streaming: max time to read the full response body (ms).
UPSTREAM_BODY_MS=60000
# Streaming: max gap allowed between chunks before a hung stream is aborted (ms).
UPSTREAM_STREAM_IDLE_MS=30000

# SSRF protection (network security) — sets the baseline; the dashboard Settings
# tab can add more allowlisted hosts on top of these at runtime.
# Blocking is ON by default: provider URLs pointing at private/loopback/internal
# addresses are refused. Set to true ONLY on a fully trusted network.
SSRF_ALLOW_PRIVATE=false
# Comma-separated hosts to permit even while blocking is on — for local providers
# (e.g. Ollama). Use host or host:port, no scheme. Example:
#   SSRF_ALLOWLIST=localhost:11434,127.0.0.1:11434
SSRF_ALLOWLIST=

# Guardrails / content filtering (optional, OFF by default) — sets the baseline;
# the dashboard Settings tab can manage the same values at runtime.
# Redact PII or block banned content / injection patterns. Rules are a JSON array
# of { name, pattern (regex), action: block|redact, appliesTo: input|output|both,
# replacement }. Example: [{"name":"email","pattern":"[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}","action":"redact","appliesTo":"both","replacement":"[REDACTED_EMAIL]"}]
GUARDRAILS_ENABLED=false
GUARDRAILS_RULES=
# Streamed responses can only be output-filtered by buffering them first, which
# gives up the streaming latency win. Off by default; input filtering always applies.
GUARDRAILS_BUFFERED_SAFE=false

# Cost-aware routing (optional). Among healthy, in-headroom providers within a tier,
# bias toward the cheaper one using model-registry pricing. 0 = ignore cost (default,
# unchanged behavior), 1 = strict cheapest-first. Never overrides tier priority,
# breaker/rate-limit state, or sticky cache affinity. Editable in dashboard Settings.
ROUTING_COST_WEIGHT=0

# Async analytics pipeline. Usage events are buffered in-process and written to
# Postgres in one batched insert on this interval (ms) or when the buffer reaches
# the size threshold — so the request path never waits on an analytics write. The
# cap bounds memory: if the database is unreachable, events beyond it are shed.
USAGE_FLUSH_INTERVAL_MS=1500
USAGE_FLUSH_MAX=100
USAGE_BUFFER_CAP=10000

# Response cache (optional, OFF by default). When enabled, an exact-match request
# (same model + messages + generation params) is served from Redis, skipping the
# provider entirely — a real $0 call. Identical requests return the cached answer
# until the TTL expires. Editable in dashboard Settings.
CACHE_ENABLED=false
CACHE_TTL_SECONDS=3600

# Observability. /metrics (Prometheus) is auth-guarded by a bearer token. Set a
# dedicated scrape token here (recommended, so you don't hand Prometheus the admin
# password); if unset, /metrics falls back to accepting ADMIN_PASSWORD.
METRICS_TOKEN=
# OpenTelemetry (optional): spans for the gateway→provider call are emitted only if
# you run the app with an OTel SDK, e.g.
#   node --require @opentelemetry/auto-instrumentations-node/register dist/server.js
# and point OTEL_EXPORTER_OTLP_ENDPOINT at your collector. No SDK = zero overhead.

# ── Admin authentication (Phases 6 and 7.13a) ───────────────────────────────────
# Signing in exchanges your EMAIL AND PASSWORD for a session token. On a gateway that
# has not been claimed yet, ADMIN_PASSWORD signs in instead — exactly as before 7.13a —
# and the dashboard shows a one-time screen to create your owner account. After that it
# is no longer a sign-in. Two-factor auth is each person's own: off until they enrol an
# authenticator, and once enrolled a password alone is not enough for that account.

# How long a dashboard session lasts before re-authenticating. Default 12 hours.
ADMIN_SESSION_TTL_SECONDS=43200
# Failed sign-ins from one source before it is locked out. Default 5.
ADMIN_MAX_LOGIN_ATTEMPTS=5
# How long that lockout lasts, in seconds. Default 15 minutes.
ADMIN_LOCKOUT_SECONDS=900

# ── Public URL (P7.14) ──────────────────────────────────────────────────────────
# The address the outside world reaches this gateway at — what the Connect page, the
# quick-start snippets, and the SSO redirect_uri print. Leave unset and the gateway
# infers it per request: the proxy's X-Forwarded-Proto / X-Forwarded-Host headers when
# present, else the Host header with http:// assumed. That inference has one hole the
# gateway cannot close itself: a proxy that forwards Host but omits X-Forwarded-Proto
# makes a TLS deployment print http:// with confidence — TLS it didn't terminate is
# invisible to it. If your URLs print with the wrong scheme, either configure the proxy
# to send X-Forwarded-Proto, or pin the address here and it wins over everything:
#   PUBLIC_URL=https://gateway.example.com
# A pasted /v1 or trailing slash is tolerated; any other path is refused at boot.
PUBLIC_URL=

# ── Docker Compose only ─────────────────────────────────────────────────────────
# Which published image tag `docker compose up` runs. Defaults to `latest`; pin a
# version in production. Ignored when building from source with docker-compose.dev.yml.
NEXUS_VERSION=1.2.0
