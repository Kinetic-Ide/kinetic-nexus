# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ───────────────────────────────────────────────────────────────
dist/
build/

# ── Environment & Secrets ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor ─────────────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~

# ── Testing & Coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Prisma ─────────────────────────────────────────────────────────────────────
# Keep migrations committed — they are deployment history
# Ignore only local dev shadow DB artifacts
prisma/*.db
prisma/*.db-journal

# ── Internal planning docs (not for public repo) ────────────────────────────────
# Roadmaps/upgrade plans live here for internal use only. User-facing docs
# (Phase 10 "Docs tab" content, API reference, quickstart) must NOT live under
# an ignored path — put those under a committed one so they aren't accidentally
# hidden from the OSS repo.
#
# `docs/*` rather than `docs/`: git will not descend into an ignored *directory*,
# so a negation for a child would never be evaluated.
docs/*
!docs/architecture/
!docs/assets/
# The built static demo. Committed on purpose: GitHub Pages publishes it straight from the default
# branch, so the artefact has to be in the tree — and keeping it here means a fork gets the demo
# without running a build. Rebuilt by `npm run build:demo` in web/.
!docs/demo/

# ── Misc ───────────────────────────────────────────────────────────────────────
.claude/
*.tgz

# ── E2E (Playwright artefacts; e2e/node_modules is caught by the global rule) ──
e2e/test-results/
e2e/playwright-report/
e2e/.state/

# Local scratch: session tokens and boot logs from dev runs; npm cache redirected off C:
.tmp/
.npmcache/
