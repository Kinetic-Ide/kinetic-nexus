{
  "name": "alayra-nexus",
  "version": "1.3.2",
  "description": "AI key pool proxy — route Claude, Gemini, GPT through one OpenAI-compatible endpoint",
  "license": "Apache-2.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "npx prisma migrate deploy",
    "db:push": "npx prisma db push",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/client": "^5.10.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "ioredis": "^5.3.2",
    "jose": "^5.10.0",
    "js-tiktoken": "^1.0.21",
    "prisma": "^5.10.2",
    "prom-client": "^15.1.3",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.24",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
